// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  DISPATCHER
  ADMIN
}

enum RequestStatus {
  DRAFT
  SENT
  IN_REVIEW
  REVIEWED
  APPROVED
  REJECTED
  CANCELLED
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

model User {
  id           String     @id @default(cuid())
  clerkId      String?    @unique // Clerk user id (null only for legacy seed rows)
  email        String     @unique
  passwordHash String? // legacy / unused under Clerk auth — drop in a later migration
  fullName     String
  phone        String? // editable on profile
  city         String? // editable on profile
  company      String? // editable on profile (cliente · finca/empresa)
  photoUrl     String? // public R2 URL, ~400px webp
  role         Role? // assigned by an admin at approval time
  status       UserStatus @default(PENDING)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  requestsAsClient    Request[]              @relation("ClientRequests")
  statusChangesByUser RequestStatusHistory[]
}

model Category {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  displayOrder Int        @default(0)
  parentId     String? // legacy (unused); kept to avoid a destructive migration
  parent       Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryHierarchy")
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  products Product[]
  models   EquipmentModel[]
}

model PartType {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  displayOrder Int     @default(0)
  active       Boolean @default(true)

  products Product[]
}

model Brand {
  id      String   @id @default(cuid())
  name    String   @unique
  aliases String[] // e.g. ["STHIL", "ESTIHL"] — used to normalize searches
  active  Boolean  @default(true)

  products Product[]
  models   EquipmentModel[]
}

model EquipmentModel {
  id         String   @id @default(cuid())
  code       String   @unique // "MS660", "FS280", "GX35"
  name       String // "STIHL MS660"
  brandId    String?
  brand      Brand?   @relation(fields: [brandId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  active     Boolean  @default(true)

  products ProductModel[]
}

model Product {
  id             String    @id @default(cuid())
  code           String    @unique // internal code (E55, G20, MS660-001, …)
  name           String
  description    String?
  price          Decimal   @default(0) @db.Decimal(10, 2)
  categoryId     String
  category       Category  @relation(fields: [categoryId], references: [id])
  partTypeId     String?
  partType       PartType? @relation(fields: [partTypeId], references: [id])
  brandId        String?
  brand          Brand?    @relation(fields: [brandId], references: [id])
  isCompleteUnit Boolean   @default(false) // true = assembled equipment; false = spare part
  isNew          Boolean   @default(false) // "NEW" flag from the physical catalog
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  images           ProductImage[]
  compatibleModels ProductModel[]
  requestItems     RequestItem[]

  @@index([name])
  @@index([code])
  @@index([categoryId])
  @@index([brandId])
}

model ProductModel {
  productId String
  modelId   String
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  model     EquipmentModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@id([productId, modelId])
  @@index([modelId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  urlThumb  String // ~200px
  urlMedium String // ~600px
  urlFull   String // ~1200px
  position  Int      @default(0)
  createdAt DateTime @default(now())
}

model Request {
  id         String        @id @default(cuid())
  clientId   String
  client     User          @relation("ClientRequests", fields: [clientId], references: [id])
  status     RequestStatus @default(DRAFT)
  notes      String?
  createdAt  DateTime      @default(now())
  sentAt     DateTime?
  reviewedAt DateTime?
  decidedAt  DateTime?
  updatedAt  DateTime      @updatedAt

  items   RequestItem[]
  history RequestStatusHistory[]

  @@index([clientId])
  @@index([status])
}

model RequestItem {
  id           String   @id @default(cuid())
  requestId    String
  request      Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int
  available    Boolean? // null = not yet reviewed
  observations String?

  @@unique([requestId, productId])
}

model RequestStatusHistory {
  id          String         @id @default(cuid())
  requestId   String
  request     Request        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fromStatus  RequestStatus?
  toStatus    RequestStatus
  changedById String
  changedBy   User           @relation(fields: [changedById], references: [id])
  notes       String?
  changedAt   DateTime       @default(now())

  @@index([requestId])
}
